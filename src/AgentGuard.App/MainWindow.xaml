<Window x:Class="AgentGuard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:localization="clr-namespace:AgentGuard.App.Localization"
        Title="{x:Static localization:AppText.WindowTitle}"
        Width="1320"
        Height="760"
        MinWidth="1080"
        MinHeight="640"
        Loaded="Window_Loaded"
        Closed="Window_Closed">
  <DockPanel>
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource ElevatedBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="20,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal">
          <Border Width="44" Height="44" CornerRadius="13" Background="{DynamicResource AccentGradientBrush}" Margin="0,0,12,0">
            <Image Source="/AgentGuard;component/Assets/AppIcon.png" Margin="7" />
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="{x:Static localization:AppText.ProductName}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="24"
                       FontWeight="Bold" />
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,3,0,0" />
          </StackPanel>
        </StackPanel>
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
            <Ellipse Width="10" Height="10" Margin="0,0,6,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="{DynamicResource DangerBrush}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                      <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="{x:Static localization:AppText.Server}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0" />
            <Ellipse Width="10" Height="10" Margin="0,0,6,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="{DynamicResource DangerBrush}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMonitoring}" Value="True">
                      <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="{x:Static localization:AppText.Monitor}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
          </StackPanel>
          <Button Content="{x:Static localization:AppText.StartServer}" Command="{Binding StartServerCommand}" ToolTip="{x:Static localization:AppText.StartServerTip}" />
          <Button Content="{x:Static localization:AppText.StopServer}" Command="{Binding StopServerCommand}" ToolTip="{x:Static localization:AppText.StopServerTip}" />
          <Button Content="{x:Static localization:AppText.Refresh}" Command="{Binding RefreshAllCommand}" ToolTip="{x:Static localization:AppText.RefreshTip}" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Margin="16">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <UniformGrid Columns="5" Margin="0,0,0,14">
        <Border Background="{DynamicResource ElevatedBrush}" Padding="14" Margin="0,0,10,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
          <StackPanel>
            <TextBlock Text="{x:Static localization:AppText.Pending}" Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock Text="{Binding PendingCount}" FontSize="24" FontWeight="SemiBold" />
          </StackPanel>
        </Border>
        <Border Background="{DynamicResource ElevatedBrush}" Padding="14" Margin="0,0,10,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
          <StackPanel>
            <TextBlock Text="{x:Static localization:AppText.ActiveSessions}" Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock Text="{Binding ActiveSessionCount}" FontSize="24" FontWeight="SemiBold" />
          </StackPanel>
        </Border>
        <Border Background="{DynamicResource ElevatedBrush}" Padding="14" Margin="0,0,10,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
          <StackPanel>
            <TextBlock Text="{x:Static localization:AppText.AuditRecords}" Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock Text="{Binding AuditCount}" FontSize="24" FontWeight="SemiBold" />
          </StackPanel>
        </Border>
        <Border Background="{DynamicResource ElevatedBrush}" Padding="14" Margin="0,0,10,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
          <StackPanel>
            <TextBlock Text="{x:Static localization:AppText.Alerts}" Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock Text="{Binding AlertCount}" FontSize="24" FontWeight="SemiBold" />
          </StackPanel>
        </Border>
        <Border Background="{DynamicResource ElevatedBrush}" Padding="14" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
          <StackPanel>
            <TextBlock Text="{x:Static localization:AppText.Agents}" Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock Text="{Binding InstalledAgentCount}" FontSize="24" FontWeight="SemiBold" />
          </StackPanel>
        </Border>
      </UniformGrid>

      <TabControl Grid.Row="1" Background="{DynamicResource CanvasGradientBrush}">
        <TabItem Header="{x:Static localization:AppText.Approvals}" Tag="&#xE72E;">
          <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>
            <DataGrid ItemsSource="{Binding PendingRequests}"
                      SelectedItem="{Binding SelectedPendingRequest}"
                      Margin="0,0,12,0">
              <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static localization:AppText.Type}" Binding="{Binding Type, Converter={StaticResource EnumTextConverter}}" Width="105" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Agent}" Binding="{Binding AgentName}" Width="130" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Title}" Binding="{Binding Title}" Width="180" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Project}" Binding="{Binding Project}" Width="160" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Requested}" Binding="{Binding RequestedAt, StringFormat={}{0:t}}" Width="100" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Path}" Binding="{Binding Cwd}" Width="*" />
              </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1"
                    Background="{DynamicResource ElevatedBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                  <TextBlock Text="{Binding SelectedPendingRequest.Type, Converter={StaticResource EnumTextConverter}}" Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Text="{Binding SelectedPendingRequest.Title}"
                             FontSize="20"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap"
                             Margin="0,4,0,8" />
                  <TextBlock Text="{Binding SelectedPendingRequest.AgentName}" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" Margin="0,14,0,14">
                  <StackPanel>
                    <TextBlock Text="{x:Static localization:AppText.Detail}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBox Text="{Binding SelectedPendingRequest.Detail}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="180"
                             IsReadOnly="True"
                             Margin="0,6,0,12" />
                    <TextBlock Text="{x:Static localization:AppText.ToolInput}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBox Text="{Binding SelectedPendingRequest.ToolInput}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="100"
                             IsReadOnly="True"
                             Margin="0,6,0,0" />
                  </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="0,0,0,12">
                  <TextBlock Text="{x:Static localization:AppText.ReplyReason}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBox Text="{Binding QuestionAnswer, UpdateSourceTrigger=PropertyChanged}"
                           TextWrapping="Wrap"
                           AcceptsReturn="True"
                           MinHeight="60"
                           Margin="0,6,0,8" />
                  <TextBox Text="{Binding ResponseReason, UpdateSourceTrigger=PropertyChanged}"
                           TextWrapping="Wrap"
                           AcceptsReturn="True"
                           MinHeight="42"
                           ToolTip="{x:Static localization:AppText.OptionalReasonOrPlanMessage}" />
                </StackPanel>

                <WrapPanel Grid.Row="3">
                  <Button Content="{x:Static localization:AppText.Allow}" Command="{Binding ApproveCommand}" />
                  <Button Content="{x:Static localization:AppText.Deny}" Command="{Binding DenyCommand}" />
                  <Button Content="{x:Static localization:AppText.Answer}" Command="{Binding AnswerQuestionCommand}" />
                  <Button Content="{x:Static localization:AppText.AcceptPlan}" Command="{Binding AcceptPlanCommand}" />
                  <Button Content="{x:Static localization:AppText.CancelPlan}" Command="{Binding CancelPlanCommand}" />
                </WrapPanel>
              </Grid>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="{x:Static localization:AppText.MonitorOverview}" Tag="&#xE9D2;">
          <Grid Margin="0,12,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <UniformGrid Columns="5" Margin="0,0,0,12">
              <Border Background="{DynamicResource ElevatedBrush}" Padding="14" Margin="0,0,10,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                  <TextBlock Text="{x:Static localization:AppText.TotalTokens}" Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Text="{Binding MonitorOverviewTotalTokens}" FontSize="22" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Background="{DynamicResource ElevatedBrush}" Padding="14" Margin="0,0,10,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                  <TextBlock Text="{x:Static localization:AppText.AvgContext}" Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Text="{Binding MonitorOverviewAverageContext}" FontSize="22" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Background="{DynamicResource ElevatedBrush}" Padding="14" Margin="0,0,10,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                  <TextBlock Text="{x:Static localization:AppText.ToolCalls}" Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Text="{Binding MonitorOverviewToolCalls}" FontSize="22" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Background="{DynamicResource ElevatedBrush}" Padding="14" Margin="0,0,10,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                  <TextBlock Text="{x:Static localization:AppText.Commands}" Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Text="{Binding MonitorOverviewCommands}" FontSize="22" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Background="{DynamicResource ElevatedBrush}" Padding="14" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                  <TextBlock Text="{x:Static localization:AppText.RateLimit}" Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Text="{Binding MonitorOverviewRateLimit}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </UniformGrid>

            <DockPanel Grid.Row="1" Margin="0,0,0,10">
              <Button DockPanel.Dock="Right"
                      Content="{x:Static localization:AppText.ScanAgentHistory}"
                      Command="{Binding ScanAgentHistoryCommand}"
                      ToolTip="{x:Static localization:AppText.ScanAgentHistoryTip}" />
              <StackPanel>
                <TextBlock Text="{x:Static localization:AppText.MonitorOverviewSubtitle}" Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBlock Text="{Binding MonitorOverviewStatusMessage}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0" />
              </StackPanel>
            </DockPanel>

            <DataGrid Grid.Row="2" ItemsSource="{Binding MonitorOverviewRows}">
              <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static localization:AppText.Agent}" Binding="{Binding AgentName}" Width="130" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Project}" Binding="{Binding Project}" Width="150" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Status}" Binding="{Binding Status}" Width="115" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Model}" Binding="{Binding Model}" Width="145" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Tokens}" Binding="{Binding TotalTokens}" Width="95" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Context}" Binding="{Binding ContextUsedPercent, StringFormat={}{0:0.#}%}" Width="85" />
                <DataGridTextColumn Header="{x:Static localization:AppText.ToolCalls}" Binding="{Binding ToolCalls}" Width="80" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Commands}" Binding="{Binding Commands}" Width="80" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Files}" Binding="{Binding FileAccesses}" Width="70" />
                <DataGridTextColumn Header="{x:Static localization:AppText.RateLimit}" Binding="{Binding RateLimitText}" Width="110" />
                <DataGridTextColumn Header="{x:Static localization:AppText.LastActivity}" Binding="{Binding LastActivity, StringFormat={}{0:g}}" Width="135" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Source}" Binding="{Binding SourceFile}" Width="*" />
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </TabItem>

        <TabItem Header="{x:Static localization:AppText.Audit}" Tag="&#xE9D9;">
          <DataGrid ItemsSource="{Binding AuditRecords}" Margin="0,12,0,0">
            <DataGrid.Columns>
              <DataGridTextColumn Header="{x:Static localization:AppText.Time}" Binding="{Binding Timestamp, StringFormat={}{0:t}}" Width="90" />
              <DataGridTextColumn Header="{x:Static localization:AppText.Agent}" Binding="{Binding AgentName}" Width="140" />
              <DataGridTextColumn Header="{x:Static localization:AppText.Type}" Binding="{Binding OperationType, Converter={StaticResource EnumTextConverter}}" Width="90" />
              <DataGridTextColumn Header="{x:Static localization:AppText.Target}" Binding="{Binding TargetPath}" Width="*" />
              <DataGridTextColumn Header="{x:Static localization:AppText.Detail}" Binding="{Binding Detail}" Width="260" />
            </DataGrid.Columns>
          </DataGrid>
        </TabItem>

        <TabItem Header="{x:Static localization:AppText.Integrations}" Tag="&#xE774;">
          <Grid Margin="0,12,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
              <Button Content="{x:Static localization:AppText.RefreshAgents}" Command="{Binding RefreshAgentsCommand}" ToolTip="{x:Static localization:AppText.RefreshAgentsTip}" />
              <Button Content="{x:Static localization:AppText.InstallSelectedHooks}" Command="{Binding InstallSelectedHooksCommand}" ToolTip="{x:Static localization:AppText.InstallSelectedHooksTip}" />
              <Button Content="{x:Static localization:AppText.InstallAllAvailable}" Command="{Binding InstallAllHooksCommand}" ToolTip="{x:Static localization:AppText.InstallAllAvailableTip}" />
            </StackPanel>
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Agents}"
                      SelectedItem="{Binding SelectedAgent}">
              <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static localization:AppText.Agent}" Binding="{Binding DisplayName}" Width="180" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Status}" Binding="{Binding Status, Converter={StaticResource EnumTextConverter}}" Width="110" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Executable}" Binding="{Binding Executable}" Width="150" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Config}" Binding="{Binding ConfigurationPath}" Width="*" />
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </TabItem>

        <TabItem Header="{x:Static localization:AppText.Sessions}" Tag="&#xE716;">
          <DataGrid ItemsSource="{Binding Sessions}" Margin="0,12,0,0">
            <DataGrid.Columns>
              <DataGridTextColumn Header="{x:Static localization:AppText.Phase}" Binding="{Binding Phase, Converter={StaticResource EnumTextConverter}}" Width="125" />
              <DataGridTextColumn Header="{x:Static localization:AppText.Agent}" Binding="{Binding AgentType}" Width="130" />
              <DataGridTextColumn Header="{x:Static localization:AppText.Project}" Binding="{Binding Project}" Width="180" />
              <DataGridTextColumn Header="{x:Static localization:AppText.LastTool}" Binding="{Binding LastToolName}" Width="180" />
              <DataGridTextColumn Header="{x:Static localization:AppText.Cwd}" Binding="{Binding Cwd}" Width="*" />
            </DataGrid.Columns>
          </DataGrid>
        </TabItem>

        <TabItem Header="{x:Static localization:AppText.History}" Tag="&#xE81C;">
          <Grid Margin="0,12,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel>
              <TextBlock Text="{x:Static localization:AppText.AgentHistoryTabDescription}" Foreground="{DynamicResource TextSecondaryBrush}" />
              <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                <Button Content="{x:Static localization:AppText.ScanAgentHistory}" Command="{Binding ScanAgentHistoryCommand}" ToolTip="{x:Static localization:AppText.ScanAgentHistoryTip}" />
                <Button Content="{x:Static localization:AppText.ClearHistoryFilter}" Command="{Binding ClearHistoryFilterCommand}" ToolTip="{x:Static localization:AppText.ClearHistoryFilterTip}" />
              </StackPanel>
              <TextBlock Text="{Binding HistoryStatusMessage}" Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="{x:Static localization:AppText.SessionsLabel}" FontWeight="SemiBold" Margin="0,12,0,4" />
              <DataGrid ItemsSource="{Binding HistorySessions}"
                        SelectedItem="{Binding SelectedSession}"
                        MaxHeight="180">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="{x:Static localization:AppText.Agent}" Binding="{Binding AgentName}" Width="160" />
                  <DataGridTextColumn Header="{x:Static localization:AppText.Project}" Binding="{Binding Project}" Width="160" />
                  <DataGridTextColumn Header="{x:Static localization:AppText.LastActivity}" Binding="{Binding LastActivity, StringFormat={}{0:g}}" Width="140" />
                  <DataGridTextColumn Header="{x:Static localization:AppText.Calls}" Binding="{Binding RecordCount}" Width="80" />
                  <DataGridTextColumn Header="{x:Static localization:AppText.Source}" Binding="{Binding SourceFile}" Width="*" />
                </DataGrid.Columns>
              </DataGrid>
              <TextBlock Text="{x:Static localization:AppText.RecordsLabel}" FontWeight="SemiBold" Margin="0,12,0,4" />
            </StackPanel>
            <DataGrid Grid.Row="1" ItemsSource="{Binding HistoryRecords}">
              <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static localization:AppText.Time}" Binding="{Binding Timestamp, StringFormat={}{0:g}}" Width="140" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Agent}" Binding="{Binding AgentName}" Width="130" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Type}" Binding="{Binding Operation, Converter={StaticResource EnumTextConverter}}" Width="90" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Project}" Binding="{Binding Project}" Width="140" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Target}" Binding="{Binding TargetPath}" Width="*" />
                <DataGridTextColumn Header="{x:Static localization:AppText.Detail}" Binding="{Binding Detail}" Width="240" />
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </TabItem>

        <TabItem Header="{x:Static localization:AppText.CommandRules}" Tag="&#xE8D7;">
          <DataGrid ItemsSource="{Binding CommandRules}" Margin="0,12,0,0">
            <DataGrid.Columns>
              <DataGridTextColumn Header="{x:Static localization:AppText.List}" Binding="{Binding ListType, Converter={StaticResource EnumTextConverter}}" Width="110" />
              <DataGridTextColumn Header="{x:Static localization:AppText.Pattern}" Binding="{Binding Pattern}" Width="180" />
              <DataGridTextColumn Header="{x:Static localization:AppText.Calls}" Binding="{Binding TotalCallCount}" Width="70" />
              <DataGridTextColumn Header="{x:Static localization:AppText.Today}" Binding="{Binding TodayCallCount}" Width="70" />
              <DataGridTextColumn Header="{x:Static localization:AppText.LastCalledBy}" Binding="{Binding LastCalledBy}" Width="160" />
              <DataGridTextColumn Header="{x:Static localization:AppText.Description}" Binding="{Binding Description}" Width="*" />
              <DataGridTextColumn Header="{x:Static localization:AppText.Consequence}" Binding="{Binding Consequence}" Width="220" />
            </DataGrid.Columns>
          </DataGrid>
        </TabItem>

        <TabItem Header="{x:Static localization:AppText.Alerts}" Tag="&#xE7BA;">
          <DataGrid ItemsSource="{Binding Alerts}" Margin="0,12,0,0">
            <DataGrid.Columns>
              <DataGridTextColumn Header="{x:Static localization:AppText.Time}" Binding="{Binding Timestamp, StringFormat={}{0:t}}" Width="90" />
              <DataGridTextColumn Header="{x:Static localization:AppText.Severity}" Binding="{Binding Severity, Converter={StaticResource EnumTextConverter}}" Width="90" />
              <DataGridTextColumn Header="{x:Static localization:AppText.Type}" Binding="{Binding AlertType, Converter={StaticResource EnumTextConverter}}" Width="130" />
              <DataGridTextColumn Header="{x:Static localization:AppText.Title}" Binding="{Binding Title}" Width="170" />
              <DataGridTextColumn Header="{x:Static localization:AppText.Message}" Binding="{Binding Message}" Width="*" />
            </DataGrid.Columns>
          </DataGrid>
        </TabItem>

        <TabItem Header="{x:Static localization:AppText.Settings}" Tag="&#xE713;">
          <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.2*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Background="{DynamicResource ElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,12,0">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel>
                <TextBlock Text="{x:Static localization:AppText.ProtectedDirectories}" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="{x:Static localization:AppText.ProtectedDirectoriesDescription}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,4,0,12" />
                <ListBox ItemsSource="{Binding ProtectedDirectories}" MinHeight="220" />
                <DockPanel Margin="0,12,0,0">
                  <Button DockPanel.Dock="Right" Content="{x:Static localization:AppText.Add}" Command="{Binding AddProtectedDirectoryCommand}" ToolTip="{x:Static localization:AppText.AddDirectoryTip}" />
                  <TextBox Text="{Binding NewProtectedDirectory, UpdateSourceTrigger=PropertyChanged}"
                           ToolTip="{x:Static localization:AppText.DirectoryExampleTip}" />
                </DockPanel>

                <TextBlock Text="{x:Static localization:AppText.BridgePathLabel}" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,4" />
                <DockPanel>
                  <Button DockPanel.Dock="Right" Content="{x:Static localization:AppText.ChooseBridgePath}" Command="{Binding ChooseBridgePathCommand}" />
                  <TextBox Text="{Binding BridgePath, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static localization:AppText.BridgePathTip}" />
                </DockPanel>

                <CheckBox Content="{x:Static localization:AppText.NotificationsEnabledLabel}"
                          IsChecked="{Binding NotificationsEnabled}"
                          ToolTip="{x:Static localization:AppText.NotificationsEnabledTip}"
                          Margin="0,16,0,0" />

                <TextBlock Text="{x:Static localization:AppText.Appearance}" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,4" />
                <TextBlock Text="{x:Static localization:AppText.ColorThemeDescription}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10" />
                <TextBlock Text="{x:Static localization:AppText.ColorTheme}" FontWeight="SemiBold" Margin="0,0,0,4" />
                <ListBox ItemsSource="{Binding AvailableThemes}"
                         SelectedItem="{Binding SelectedTheme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         BorderThickness="0"
                         Background="Transparent"
                         HorizontalContentAlignment="Stretch"
                         MaxHeight="190">
                  <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                      <UniformGrid Columns="2" />
                    </ItemsPanelTemplate>
                  </ListBox.ItemsPanel>
                  <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                      <Setter Property="Margin" Value="0,0,8,8" />
                      <Setter Property="Padding" Value="0" />
                      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                      <Setter Property="Background" Value="Transparent" />
                      <Setter Property="BorderThickness" Value="0" />
                    </Style>
                  </ListBox.ItemContainerStyle>
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource CardBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              BorderThickness="1"
                              CornerRadius="8"
                              Padding="10">
                        <StackPanel>
                          <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Width="20" Height="20" Fill="{Binding Primary}" Margin="0,0,5,0" />
                            <Ellipse Width="20" Height="20" Fill="{Binding Secondary}" Margin="-5,0,5,0" />
                            <Ellipse Width="20" Height="20" Fill="{Binding Background}" Margin="-5,0,0,0" />
                          </StackPanel>
                          <TextBlock Text="{Binding Display}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="{x:Static localization:AppText.AppearanceMode}" FontWeight="SemiBold" Margin="0,12,0,4" />
                <ComboBox ItemsSource="{Binding AvailableAppearances}"
                          SelectedItem="{Binding SelectedAppearance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          DisplayMemberPath="Display"
                          Width="280"
                          HorizontalAlignment="Left" />

                <!-- v2.1.1 multi-language dropdown -->
                <TextBlock Text="{x:Static localization:AppText.LanguageLabel}" FontSize="16" FontWeight="SemiBold" Margin="0,16,0,4" />
                <ComboBox ItemsSource="{Binding AvailableLanguages}"
                          SelectedItem="{Binding SelectedLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Width="220" HorizontalAlignment="Left">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Display}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- v2.1.3 chart layout: hourly ops + top agents -->
                <TextBlock Text="{x:Static localization:AppText.HourlyChartTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,4" />
                <Border BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource CardBrush}" BorderThickness="1" CornerRadius="8" Padding="8" MaxHeight="160">
                  <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding HourlyStatsView}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Label}" Width="60" FontFamily="Consolas" />
                            <TextBlock Text="{Binding Bar}" FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}" />
                            <TextBlock Text="{Binding CountText}" Margin="8,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Consolas" />
                          </StackPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Border>

                <TextBlock Text="{x:Static localization:AppText.TopAgentsTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,16,0,4" />
                <ItemsControl ItemsSource="{Binding TopAgentsView}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Agent}" Width="200" />
                        <TextBlock Text="{Binding Bar}" FontFamily="Consolas" Foreground="{DynamicResource SuccessBrush}" />
                        <TextBlock Text="{Binding CountText}" Margin="8,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" />
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{x:Static localization:AppText.ExportAudit}" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,4" />
                <Button HorizontalAlignment="Left" Content="{x:Static localization:AppText.ExportAudit}" Command="{Binding ExportAuditCommand}" ToolTip="{x:Static localization:AppText.ExportAuditTip}" />
              </StackPanel>
              </ScrollViewer>
            </Border>
            <Border Grid.Column="1" Background="{DynamicResource ElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
              <StackPanel>
                <TextBlock Text="{x:Static localization:AppText.Runtime}" FontSize="18" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Margin="0,12,0,10">
                  <Button Content="{x:Static localization:AppText.StartMonitoring}" Command="{Binding StartMonitoringCommand}" ToolTip="{x:Static localization:AppText.StartMonitoringTip}" />
                  <Button Content="{x:Static localization:AppText.StopMonitoring}" Command="{Binding StopMonitoringCommand}" ToolTip="{x:Static localization:AppText.StopMonitoringTip}" />
                </StackPanel>
                <TextBlock Text="{x:Static localization:AppText.ActiveAgentProcesses}" Foreground="{DynamicResource TextSecondaryBrush}" />
                <ListBox ItemsSource="{Binding ActiveAgentNames}" MinHeight="100" Margin="0,6,0,12" />
                <TextBlock Text="{x:Static localization:AppText.ProcessEvents}" Foreground="{DynamicResource TextSecondaryBrush}" />
                <DataGrid ItemsSource="{Binding ProcessEvents}" MinHeight="180">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="{x:Static localization:AppText.Time}" Binding="{Binding Timestamp, StringFormat={}{0:t}}" Width="80" />
                    <DataGridTextColumn Header="{x:Static localization:AppText.Pid}" Binding="{Binding ProcessId}" Width="60" />
                    <DataGridTextColumn Header="{x:Static localization:AppText.ParentProcessLabel}" Binding="{Binding ParentProcessId}" Width="70" />
                    <DataGridTextColumn Header="{x:Static localization:AppText.Event}" Binding="{Binding EventType, Converter={StaticResource EnumTextConverter}}" Width="70" />
                    <DataGridTextColumn Header="{x:Static localization:AppText.Agent}" Binding="{Binding AgentName}" Width="120" />
                    <DataGridTextColumn Header="{x:Static localization:AppText.Pid}" Binding="{Binding ProcessId}" Width="70" />
                    <DataGridTextColumn Header="PPID" Binding="{Binding ParentProcessId}" Width="70" />
                    <DataGridTextColumn Header="Parent" Binding="{Binding Arguments}" Width="*" />
                  </DataGrid.Columns>
                </DataGrid>
              </StackPanel>
            </Border>
          </Grid>
        </TabItem>
      </TabControl>
    </Grid>
  </DockPanel>
</Window>
